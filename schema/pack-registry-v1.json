{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pack-registry-v1.json",
  "title": "FORGE Studio Pack Registry Index",
  "description": "Schema for index.json — the curated forgepack catalog. See specs/Phase8/forge-pack-registry-spec.md. A registry entry is a superset of the pack manifest (manifest fields + distribution metadata). Validate with the manifest schema added to the same Ajv instance so the requires $ref resolves.",
  "type": "object",
  "required": ["schema_version", "packs"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "packs": {
      "type": "array",
      "items": { "$ref": "#/definitions/registryEntry" }
    }
  },
  "definitions": {
    "registryEntry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "author",
        "modules",
        "scripts",
        "download_url",
        "sha256",
        "size",
        "verified"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Unique pack identifier (kebab-case)"
        },
        "name": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+",
          "description": "Semantic version"
        },
        "author": { "type": "string" },
        "license": { "type": "string" },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "min_studio_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+"
        },
        "requires": { "$ref": "pack-manifest-v1.json#/properties/requires" },
        "workflows": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Carried over from the manifest; not used for catalog presentation"
        },
        "modules": {
          "type": "object",
          "required": ["matlab", "python", "julia"],
          "additionalProperties": false,
          "properties": {
            "matlab": { "type": "boolean" },
            "python": { "type": "boolean" },
            "julia": { "type": "boolean" }
          },
          "description": "Which backends the pack ships modules for (drives card badges)"
        },
        "scripts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Relative paths of executable modules, shown in the install consent dialog"
        },
        "homepage": { "type": "string", "format": "uri" },
        "screenshots": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "download_url": {
          "type": "string",
          "format": "uri",
          "description": "GitHub release asset URL (host-allowlisted at install time)"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 of the .forgepack archive bytes; verified before extraction"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "Archive size in bytes; enforced as a download ceiling"
        },
        "verified": {
          "type": "boolean",
          "description": "Reviewed + published by maintainers (always true in pure-curated v1)"
        },
        "downloads": { "type": "integer", "minimum": 0 },
        "published_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
